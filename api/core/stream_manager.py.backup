"""
Unified Atomic Stream Architecture - Bulletproof orchestrator.

Eliminates ghost orders, doubled positions, and vanished messages.
Exactly-once processing through claim-first pattern and atomic ACK/commit handshake.
"""

import asyncio
import json
import logging
import signal
from datetime import datetime, timezone, timedelta
from typing import Dict, Any, Optional, List, Tuple
from uuid import uuid4
from dateutil.parser import isoparse

import redis.asyncio as redis
from sqlalchemy.ext.asyncio import AsyncSession, create_async_engine
from sqlalchemy.orm import sessionmaker
from sqlalchemy import select, text, func as sql_func
from sqlalchemy.dialects.postgresql import insert as pg_insert

from .writer.safe_writer import SafeWriter
from .models import Position
from .schemas import (
    ProcessResult, OrderPayload, ExecutionPayload, 
    AgentLogPayload, MetricPayload
)
from .config import get_settings

logger = logging.getLogger(__name__)


# ============================================================================
# UNIFIED STREAM MANAGER
# ============================================================================

class UnifiedStreamManager:
    """Bulletproof atomic stream orchestrator."""
    
    def __init__(self):
        self.settings = get_settings()
        self.redis_client: Optional[redis.Redis] = None
        self.safe_writer: Optional[SafeWriter] = None
        self.consumer_group = "trading_workers"
        self.consumer_name = f"worker_{uuid4().hex[:8]}"
        self.running = False
        self.paused = False
        self.shutdown_event = asyncio.Event()
        
        # Concurrency and backpressure
        self.semaphore = asyncio.Semaphore(50)  # High-scale throughput control
        self.backoff_seconds = 1
        self.max_backoff = 30
        
        # Stream to handler mapping
        self.handler_registry: Dict[str, callable] = {
            'orders': self._handle_orders,
            'executions': self._handle_executions,
            'agent_logs': self._handle_agent_logs,
            'system_metrics': self._handle_system_metrics,
            'trade_performance': self._handle_trade_performance,
            'learning_events': self._handle_learning_events,
            'risk_alerts': self._handle_risk_alerts,
        }
        
        self.dlq_stream = "dead_letter_stream"
        self.max_retries = 3
        self.stale_message_ms = 300000  # 5 minutes
        
        # Health tracking
        self.last_heartbeat = datetime.now(timezone.utc)
        self.processed_count = 0
        self.error_count = 0
        self.consecutive_db_errors = 0
        self.circuit_breaker_threshold = 10

    async def initialize(self):
        """Initialize Redis connection and SafeWriter."""
        # Redis connection with health checks
        self.redis_client = redis.Redis(
            host=self.settings.REDIS_HOST,
            port=self.settings.REDIS_PORT,
            password=self.settings.REDIS_PASSWORD,
            decode_responses=True,
            socket_connect_timeout=5,
            socket_timeout=5,
            retry_on_timeout=True,
            health_check_interval=30,
        )
        
        # Test Redis connection
        await self.redis_client.ping()
        
        # Database session factory
        database_url = self.settings.DATABASE_URL.replace("postgresql://", "postgresql+asyncpg://")
        engine = create_async_engine(
            database_url,
            pool_size=50,  # Match semaphore limit
            max_overflow=100,
            pool_pre_ping=True,
            pool_recycle=3600,
        )
        session_factory = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)
        
        self.safe_writer = SafeWriter(session_factory)
        
        # Create consumer groups
        await self._ensure_consumer_groups()
        
        # Start background tasks
        asyncio.create_task(self._autoclaim_loop())
        asyncio.create_task(self._heartbeat_loop())

    async def _ensure_consumer_groups(self):
        """Create consumer groups for all streams."""
        streams = list(self.handler_registry.keys()) + [self.dlq_stream]
        
        for stream in streams:
            try:
                await self.redis_client.xgroup_create(
                    stream, self.consumer_group, id='0', mkstream=True
                )
                logger.info(f"Created consumer group for {stream}")
            except redis.ResponseError as e:
                if "BUSYGROUP" not in str(e):
                    logger.error(f"Error creating group for {stream}: {e}")

    # ============================================================================
    # ATOMIC MESSAGE PROCESSING
    # ============================================================================

    async def _read_messages(self, stream: str, count: int = 10, block_ms: int = 1000) -> List[Dict]:
        """Read messages with backpressure control."""
        if self.paused:
            await asyncio.sleep(0.1)
            return []
        
        try:
            result = await self.redis_client.xreadgroup(
                self.consumer_group,
                self.consumer_name,
                {stream: '>'},
                count=count,
                block=block_ms
            )
            
            messages = []
            for stream_name, message_data in result:
                for message_id, fields in message_data:
                    # Parse JSON fields
                    parsed_data = {}
                    for key, value in fields.items():
                        try:
                            parsed_data[key] = json.loads(value)
                        except (json.JSONDecodeError, TypeError):
                            parsed_data[key] = value
                    
                    messages.append({
                        'stream': stream_name,
                        'message_id': message_id,
                        'data': parsed_data
                    })
            
            return messages
        except redis.ResponseError as e:
            logger.error(f"[REDIS_ERROR] stream={stream} err={e}")
            return []

    async def _process_message(self, message: Dict[str, Any]) -> bool:
        """Process message with atomic claim-first pattern."""
        async with self.semaphore:  # Prevent burst death
            stream = message['stream']
            message_id = message['message_id']
            data = message['data']
            msg_id = data.get('msg_id', message_id)
            trace_id = data.get('trace_id', message_id)
            
            try:
                # Get handler
                handler = self.handler_registry.get(stream)
                if not handler:
                    logger.error(f"[HANDLER_MISSING] msg={msg_id} stream={stream}")
                    await self._atomic_ack(stream, message_id)
                    return False
                
                # Process with atomic claim-first
                result = await handler(msg_id, stream, data, trace_id)
                
                # Atomic ACK based on result
                if result.status in [ProcessResult.SUCCESS, ProcessResult.ALREADY_PROCESSED]:
                    await self._atomic_ack(stream, message_id)
                    self.processed_count += 1
                    return True
                elif result.status == ProcessResult.DB_ERROR:
                    # Handle DB errors with retry logic
                    retry_count = message.get('retry_count', 0)
                    if retry_count >= self.max_retries:
                        await self._send_to_dlq(message, result.message or "DB error after max retries")
                    else:
                        # Don't ACK, let it be reclaimed
                        logger.warning(f"[DB_RETRY] msg={msg_id} stream={stream} retry={retry_count}")
                    return False
                else:
                    # Validation error - send to DLQ immediately
                    await self._send_to_dlq(message, result.message or "Validation failed")
                    return False
                    
            except Exception as e:
                self.error_count += 1
                logger.error(f"[PROCESS_ERROR] msg={msg_id} stream={stream} trace_id={trace_id} err={e}")
                
                # Implement backpressure and circuit breaker on DB errors
                if "connection" in str(e).lower() or "timeout" in str(e).lower():
                    self.consecutive_db_errors += 1
                    self.backoff_seconds = min(self.backoff_seconds * 2, self.max_backoff)
                    logger.warning(f"[BACKPRESSURE] msg={msg_id} backoff={self.backoff_seconds}s db_errors={self.consecutive_db_errors}")
                    
                    # Circuit breaker
                    if self.consecutive_db_errors >= self.circuit_breaker_threshold:
                        logger.error(f"[CIRCUIT_BREAKER] Pausing due to {self.consecutive_db_errors} consecutive DB errors")
                        self.paused = True
                else:
                    self.consecutive_db_errors = 0
                
                return False

    async def _atomic_ack(self, stream: str, message_id: str):
        """Atomic acknowledge - only called after successful DB commit."""
        try:
            await self.redis_client.xack(stream, self.consumer_group, message_id)
        except redis.ResponseError as e:
            logger.error(f"[ACK_ERROR] msg={message_id} stream={stream} err={e}")

    # ============================================================================
    # STREAM HANDLERS WITH VALIDATION
    # ============================================================================

    async def _handle_orders(self, msg_id: str, stream: str, data: Dict[str, Any], trace_id: str) -> ProcessResult:
        """Handle orders with strict validation."""
        try:
            # Validate payload
            payload = OrderPayload(**data)
            
            # Convert to dict for SafeWriter
            order_data = payload.dict(exclude_unset=True)
            
            # Write with claim-first pattern
            success = await self.safe_writer.write_order(msg_id, stream, order_data)
            
            if success:
                return ProcessResult(ProcessResult.SUCCESS)
            else:
                return ProcessResult(ProcessResult.ALREADY_PROCESSED)
                
        except ValidationError as e:
            error_msg = f"Order validation failed: {e}"
            logger.error(f"[CRITICAL_DATA_ERROR] msg={msg_id} stream={stream} trace_id={trace_id} err={error_msg}")
            return ProcessResult(ProcessResult.VALIDATION_ERROR, error_msg)
        except Exception as e:
            return ProcessResult(ProcessResult.DB_ERROR, str(e))

    async def _handle_executions(self, msg_id: str, stream: str, data: Dict[str, Any], trace_id: str) -> ProcessResult:
        """Handle executions with atomic position upsert."""
        try:
            # Validate payload
            payload = ExecutionPayload(**data)
            
            # Convert to dict
            execution_data = payload.dict(exclude_unset=True)
            
            # Write with claim-first pattern
            success = await self.safe_writer.write_execution(msg_id, stream, execution_data)
            
            if success:
                return ProcessResult(ProcessResult.SUCCESS)
            else:
                return ProcessResult(ProcessResult.ALREADY_PROCESSED)
                
        except ValidationError as e:
            error_msg = f"Execution validation failed: {e}"
            logger.error(f"[CRITICAL_DATA_ERROR] msg={msg_id} stream={stream} trace_id={trace_id} err={error_msg}")
            return ProcessResult(ProcessResult.VALIDATION_ERROR, error_msg)
        except Exception as e:
            return ProcessResult(ProcessResult.DB_ERROR, str(e))

    async def _handle_agent_logs(self, msg_id: str, stream: str, data: Dict[str, Any], trace_id: str) -> ProcessResult:
        """Handle agent logs with timezone-safe parsing."""
        try:
            # Validate and parse timestamp
            if 'timestamp' in data:
                data['timestamp'] = self._safe_parse_iso(data['timestamp'])
            
            payload = AgentLogPayload(**data)
            log_data = payload.dict(exclude_unset=True)
            log_data['trace_id'] = trace_id  # Ensure trace_id is set
            
            success = await self.safe_writer.write_agent_log(msg_id, stream, log_data)
            
            if success:
                return ProcessResult(ProcessResult.SUCCESS)
            else:
                return ProcessResult(ProcessResult.ALREADY_PROCESSED)
                
        except ValidationError as e:
            error_msg = f"Agent log validation failed: {e}"
            logger.error(f"[CRITICAL_DATA_ERROR] msg={msg_id} stream={stream} trace_id={trace_id} err={error_msg}")
            return ProcessResult(ProcessResult.VALIDATION_ERROR, error_msg)
        except Exception as e:
            return ProcessResult(ProcessResult.DB_ERROR, str(e))

    async def _handle_system_metrics(self, msg_id: str, stream: str, data: Dict[str, Any], trace_id: str) -> ProcessResult:
        """Handle system metrics."""
        try:
            # Validate and parse timestamp
            if 'timestamp' in data:
                data['timestamp'] = self._safe_parse_iso(data['timestamp'])
            
            payload = MetricPayload(**data)
            metric_data = payload.dict(exclude_unset=True)
            
            success = await self.safe_writer.write_system_metric(msg_id, stream, metric_data)
            
            if success:
                return ProcessResult(ProcessResult.SUCCESS)
            else:
                return ProcessResult(ProcessResult.ALREADY_PROCESSED)
                
        except ValidationError as e:
            error_msg = f"Metric validation failed: {e}"
            logger.error(f"[CRITICAL_DATA_ERROR] msg={msg_id} stream={stream} trace_id={trace_id} err={error_msg}")
            return ProcessResult(ProcessResult.VALIDATION_ERROR, error_msg)
        except Exception as e:
            return ProcessResult(ProcessResult.DB_ERROR, str(e))

    async def _handle_trade_performance(self, msg_id: str, stream: str, data: Dict[str, Any], trace_id: str) -> ProcessResult:
        """Handle trade performance."""
        try:
            # Parse timestamps
            for time_field in ['entry_time', 'exit_time']:
                if time_field in data and data[time_field]:
                    data[time_field] = self._safe_parse_iso(data[time_field])
            
            success = await self.safe_writer.write_trade_performance(msg_id, stream, data)
            
            if success:
                return ProcessResult(ProcessResult.SUCCESS)
            else:
                return ProcessResult(ProcessResult.ALREADY_PROCESSED)
                
        except Exception as e:
            return ProcessResult(ProcessResult.DB_ERROR, str(e))

    async def _handle_learning_events(self, msg_id: str, stream: str, data: Dict[str, Any], trace_id: str) -> ProcessResult:
        """Handle learning events."""
        try:
            event_type = data.get('event_type')
            if event_type == 'vector_memory':
                success = await self.safe_writer.write_vector_memory(msg_id, stream, data)
            elif event_type == 'factor_ic_update':
                success = await self.safe_writer.write_factor_ic(msg_id, stream, data)
            else:
                error_msg = f"Unknown learning event type: {event_type}"
                logger.warning(f"[UNKNOWN_EVENT] msg={msg_id} stream={stream} trace_id={trace_id} err={error_msg}")
                return ProcessResult(ProcessResult.VALIDATION_ERROR, error_msg)
            
            if success:
                return ProcessResult(ProcessResult.SUCCESS)
            else:
                return ProcessResult(ProcessResult.ALREADY_PROCESSED)
                
        except Exception as e:
            return ProcessResult(ProcessResult.DB_ERROR, str(e))

    async def _handle_risk_alerts(self, msg_id: str, stream: str, data: Dict[str, Any], trace_id: str) -> ProcessResult:
        """Handle risk alerts."""
        try:
            success = await self.safe_writer.write_risk_alert(msg_id, stream, data)
            
            if success:
                return ProcessResult(ProcessResult.SUCCESS)
            else:
                return ProcessResult(ProcessResult.ALREADY_PROCESSED)
                
        except Exception as e:
            return ProcessResult(ProcessResult.DB_ERROR, str(e))

    # ============================================================================
    # BACKGROUND TASKS
    # ============================================================================

    async def _autoclaim_loop(self):
        """Recover stale messages from crashed workers."""
        while self.running:
            try:
                await asyncio.sleep(60)  # Run every 60 seconds
                
                for stream in self.handler_registry.keys():
                    try:
                        # Use XAUTOCLAIM to recover stale messages
                        result = await self.redis_client.xautoclaim(
                            stream, self.consumer_group, self.consumer_name,
                            min_idle_time=self.stale_message_ms, count=10
                        )
                        
                        if result:
                            reclaimed_messages = []
                            for message_id, fields in result.items():
                                parsed_data = {}
                                for key, value in fields.items():
                                    try:
                                        parsed_data[key] = json.loads(value)
                                    except (json.JSONDecodeError, TypeError):
                                        parsed_data[key] = value
                                
                                message = {
                                    'stream': stream,
                                    'message_id': message_id,
                                    'data': parsed_data,
                                    'is_reclaimed': True,
                                    'retry_count': fields.get('retry_count', 0) + 1
                                }
                                reclaimed_messages.append(message)
                            
                            logger.info(f"[AUTOCLAIM] stream={stream} reclaimed={len(reclaimed_messages)}")
                            
                            # Process reclaimed messages
                            for msg in reclaimed_messages:
                                asyncio.create_task(self._process_message(msg))
                                
                    except redis.ResponseError as e:
                        logger.error(f"[AUTOCLAIM_ERROR] stream={stream} err={e}")
                        
            except Exception as e:
                logger.error(f"[AUTOCLAIM_LOOP_ERROR] err={e}")

    async def _heartbeat_loop(self):
        """Update worker heartbeat in Redis."""
        while self.running:
            try:
                await asyncio.sleep(30)  # Update every 30 seconds
                
                heartbeat_data = {
                    'worker_id': self.consumer_name,
                    'last_seen': datetime.now(timezone.utc).isoformat(),
                    'processed_count': self.processed_count,
                    'error_count': self.error_count,
                    'status': 'running' if not self.paused else 'paused'
                }
                
                await self.redis_client.hset(
                    'agent:heartbeats',
                    self.consumer_name,
                    json.dumps(heartbeat_data)
                )
                
                self.last_heartbeat = datetime.now(timezone.utc)
                
            except Exception as e:
                logger.error(f"[HEARTBEAT_ERROR] err={e}")

    # ============================================================================
    # DLQ AND UTILITIES
    # ============================================================================

    async def _send_to_dlq(self, message: Dict[str, Any], error: str):
        """Send to DLQ and ACK original message."""
        try:
            dlq_data = {
                'original_stream': message['stream'],
                'original_message_id': message['message_id'],
                'data': message['data'],
                'error': error,
                'failed_at': datetime.now(timezone.utc).isoformat(),
                'worker': self.consumer_name
            }
            
            await self.redis_client.xadd(self.dlq_stream, dlq_data)
            
            # CRITICAL: ACK original to prevent infinite retry
            await self._atomic_ack(message['stream'], message['message_id'])
            
            logger.warning(f"[DLQ] msg={message['message_id']} stream={message['stream']} err={error}")
            
        except Exception as e:
            logger.error(f"[DLQ_ERROR] msg={message['message_id']} err={e}")

    def _safe_parse_iso(self, dt_str: Optional[str]) -> Optional[str]:
        """Safely parse ISO datetime with dateutil."""
        if not dt_str:
            return None
        
        try:
            dt = isoparse(dt_str)
            return dt.isoformat()
        except Exception as e:
            logger.warning(f"[DATE_PARSE_ERROR] dt_str={dt_str} err={e}")
            return None

    async def pause_consumers(self):
        """Kill switch - pause consumption without killing process."""
        logger.info("[PAUSE] Consumers paused")
        self.paused = True

    async def resume_consumers(self):
        """Resume consumption and reset circuit breaker."""
        logger.info("[RESUME] Consumers resumed")
        self.paused = False
        self.backoff_seconds = 1  # Reset backoff
        self.consecutive_db_errors = 0  # Reset circuit breaker

    # ============================================================================
    # MAIN CONSUMER LOOP
    # ============================================================================

    async def _consumer_loop(self):
        """Main consumer loop with backpressure and restart safety."""
        logger.info(f"[START] Consumer {self.consumer_name}")
        
        consecutive_errors = 0
        max_consecutive_errors = 5
        
        while self.running and not self.shutdown_event.is_set():
            try:
                # Read from all streams
                read_tasks = []
                for stream in self.handler_registry.keys():
                    task = asyncio.create_task(self._read_messages(stream, count=5, block_ms=100))
                    read_tasks.append(task)
                
                results = await asyncio.gather(*read_tasks, return_exceptions=True)
                
                # Process all messages
                all_messages = []
                for result in results:
                    if isinstance(result, list):
                        all_messages.extend(result)
                    elif isinstance(result, Exception):
                        logger.error(f"[READ_ERROR] err={result}")
                
                # Process with concurrency control
                if all_messages:
                    process_tasks = [
                        asyncio.create_task(self._process_message(msg))
                        for msg in all_messages
                    ]
                    await asyncio.gather(*process_tasks, return_exceptions=True)
                    
                    # 🔥 Event-driven: Trigger lag update after processing
                    # This replaces polling - updates happen immediately when messages are processed
                    try:
                        from api.main import on_message_processed
                        stream_info = await self.redis.xinfo_stream("market_ticks")
                        lag = float(stream_info.get("groups", {}).get("mygroup", {}).get("lag", 0))
                        await on_message_processed(self.event_bus, "market_ticks", lag)
                    except Exception:
                        pass  # Don't let monitoring break processing
                else:
                    # Apply backpressure if needed
                    if self.backoff_seconds > 1:
                        await asyncio.sleep(self.backoff_seconds)
                    else:
                        await asyncio.sleep(0.1)
                
                # Reset error counter on success
                consecutive_errors = 0
                
            except Exception as e:
                consecutive_errors += 1
                logger.error(f"[LOOP_ERROR] {consecutive_errors}/{max_consecutive_errors} err={e}")
                
                if consecutive_errors >= max_consecutive_errors:
                    self.backoff_seconds = min(self.backoff_seconds * 2, self.max_backoff)
                    logger.warning(f"[EXPONENTIAL_BACKOFF] seconds={self.backoff_seconds}")
                
                await asyncio.sleep(min(consecutive_errors, 10))

    # ============================================================================
    # LIFECYCLE
    # ============================================================================

    async def start(self):
        """Start the unified stream manager."""
        await self.initialize()
        self.running = True
        logger.info(f"[UNIFIED_START] {self.consumer_name}")

    async def stop(self):
        """Graceful shutdown."""
        logger.info("[STOP] Shutting down unified stream manager")
        self.running = False
        self.shutdown_event.set()
        
        if self.redis_client:
            await self.redis_client.close()
        
        logger.info("[STOP] Unified stream manager stopped")

    async def run(self):
        """Run with signal handling."""
        def signal_handler(signum, frame):
            logger.info(f"[SIGNAL] Received {signum}")
            asyncio.create_task(self.stop())
        
        signal.signal(signal.SIGTERM, signal_handler)
        signal.signal(signal.SIGINT, signal_handler)
        
        await self.start()
        try:
            await self._consumer_loop()
        except Exception as e:
            logger.error(f"[FATAL_ERROR] err={e}")
        finally:
            await self.stop()


async def main():
    """Entry point."""
    manager = UnifiedStreamManager()
    await manager.run()


if __name__ == "__main__":
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
    )
    asyncio.run(main())
