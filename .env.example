# Environment Variables for Trading Dashboard
# Copy this file to .env.local and fill in your values

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Anthropic Claude API Key (Required for AI agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database URL (Required for Vercel production)
# Get from Neon, Supabase, or other PostgreSQL provider
DATABASE_URL=postgresql://username:password@host:port/database

# =============================================================================
# NEXT.JS CONFIGURATION
# =============================================================================

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =============================================================================
# VERCEL INTEGRATION
# =============================================================================

# Vercel Analytics (Optional - get from Vercel dashboard)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# Vercel Speed Insights (Optional - get from Vercel dashboard)
NEXT_PUBLIC_VERCEL_SPEED_INSIGHTS_ID=your_vercel_speed_insights_id

# =============================================================================
# FEATURE FLAGS
# =============================================================================

NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_DEBUG=false

# =============================================================================
# API CONFIGURATION
# =============================================================================

# CORS and Host settings
ALLOWED_ORIGINS=http://localhost:3000,https://*.vercel.app,https://*.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1,*.vercel.app,*.onrender.com

# API settings
API_TIMEOUT=30000
MAX_RETRIES=3
NEXT_PUBLIC_LOG_LEVEL=info

# =============================================================================
# OPTIONAL EXTERNAL APIS
# =============================================================================

# Alpha Vantage API Key (for market data)
# Get free key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# News API Key (for sentiment analysis)
# Get free key from: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# =============================================================================
# OBSERVABILITY (Optional)
# =============================================================================

# Langfuse for AI agent tracking
# Get from: https://langfuse.com/
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug logging in development
ENABLE_DEBUG_LOGGING=true
LOG_LEVEL=INFO
LOG_COLORS=true
