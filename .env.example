# Trading Control — Environment Variables
# Copy to .env and fill in your values before running locally.
# Never commit .env to git.

# =============================================================================
# DATABASE (required)
# =============================================================================

# PostgreSQL with asyncpg driver (pgvector extension required)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading_control

# =============================================================================
# REDIS (required)
# =============================================================================

REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM — pick one provider (Groq is default and free)
# =============================================================================

# Groq (default — fast, free tier available)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key

# LLM behaviour
LLM_PROVIDER=groq
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODE=skip_reasoning
ANTHROPIC_DAILY_TOKEN_BUDGET=5000000
ANTHROPIC_COST_ALERT_USD=5.0

# =============================================================================
# ALPACA — market data and order execution (paper mode)
# =============================================================================

ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true
MARKET_DATA_PROVIDER=alpaca

# =============================================================================
# APPLICATION
# =============================================================================

FRONTEND_URL=http://localhost:3000
BROKER_MODE=paper
LOG_LEVEL=INFO
ENABLE_SIGNAL_SCHEDULER=false

# =============================================================================
# AGENT THRESHOLDS
# =============================================================================

SIGNAL_EVERY_N_TICKS=10
GRADE_EVERY_N_FILLS=5
IC_UPDATE_EVERY_N_FILLS=10
REFLECT_EVERY_N_FILLS=10
REFLECTION_TRADE_THRESHOLD=20
MAX_CONSUMER_LAG_ALERT=5000

# =============================================================================
# OBSERVABILITY (optional)
# =============================================================================

# Langfuse — LLM tracing (https://langfuse.com)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
