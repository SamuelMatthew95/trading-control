# Trading Control — Environment Variables
# Copy to .env and fill in your values before running locally.
# Never commit .env to git.

# =============================================================================
# DATABASE (required unless USE_MEMORY_MODE=true)
# =============================================================================

# PostgreSQL with asyncpg driver (pgvector extension required)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trading_control

# When true, skip all PostgreSQL connection attempts and run with Redis +
# InMemoryStore as the persistence layer. The dashboard hydrates from the
# Redis-backed REST endpoints (/notifications, /decisions, /llm/health) so
# operators get a working UI without Postgres. Use this on Render when the
# DB is intentionally unavailable, to silence the DNS-failure warnings that
# would otherwise fire on every health probe.
# USE_MEMORY_MODE=false

# =============================================================================
# REDIS (required)
# =============================================================================

REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM — pick one provider (Groq is default and free)
# =============================================================================

# Groq (default — fast, free tier available)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key

# LLM behaviour
# Set to "lmstudio" to use local GPU via LM Studio as the primary provider.
# Other options: groq, gemini, anthropic, openai
LLM_PROVIDER=groq
LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODE=skip_reasoning
ANTHROPIC_DAILY_TOKEN_BUDGET=5000000
ANTHROPIC_COST_ALERT_USD=5.0
# When false, LM Studio failures are hard errors (Gemini is never called).
# Set true only if you want automatic cloud fallback when LM Studio is down.
# LLM_FALLBACK_ENABLED=false

# =============================================================================
# ALPACA — market data and order execution (paper mode)
# =============================================================================

ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true
MARKET_DATA_PROVIDER=alpaca

# =============================================================================
# APPLICATION
# =============================================================================

FRONTEND_URL=http://localhost:3000
BROKER_MODE=paper
LOG_LEVEL=INFO
ENABLE_SIGNAL_SCHEDULER=false

# =============================================================================
# AGENT THRESHOLDS
# =============================================================================

SIGNAL_EVERY_N_TICKS=10
GRADE_EVERY_N_FILLS=5
IC_UPDATE_EVERY_N_FILLS=10
REFLECT_EVERY_N_FILLS=10
REFLECTION_TRADE_THRESHOLD=20
MAX_CONSUMER_LAG_ALERT=5000

# =============================================================================
# LOCAL GPU INFERENCE — LM Studio
# =============================================================================
# Use LM Studio to run a local model as the primary LLM provider.
# LM Studio exposes an OpenAI-compatible API on port 1234 by default.
#
# QUICKSTART — recommended env vars for LM Studio as primary:
#
#   LLM_PROVIDER=lmstudio
#   LM_STUDIO_BASE_URL=http://localhost:1234/v1   # or use HOST+PORT below
#   LM_STUDIO_MODEL=<exact model name shown in LM Studio>
#   LLM_FALLBACK_ENABLED=false
#
# With LLM_PROVIDER=lmstudio you do NOT need GEMINI_API_KEY or GROQ_API_KEY.
# The system will not fall back to Gemini unless LLM_FALLBACK_ENABLED=true.
#
# REMOTE DEPLOYMENT WARNING:
#   If the backend runs on Render (or any remote host), localhost:1234 on
#   the backend machine is NOT your laptop. The health check will detect
#   this and show:
#     "Remote backend cannot reach local LM Studio at localhost."
#   To make a remote backend reach LM Studio on your laptop, use one of:
#     1. Run the backend locally alongside LM Studio.
#     2. Expose LM Studio via a secure tunnel (ngrok, Cloudflare Tunnel).
#     3. Connect both machines via Tailscale — use the Tailscale IP as
#        LM_STUDIO_HOST (see Option B below).
#     4. Deploy the model somewhere the backend can reach.
#
# CAPACITY: ReasoningAgent processes one decision at a time (consumer group
# model). That means at most 1 concurrent local inference call — a perfect
# match for a local GPU that handles one request at a time. Typical throughput:
#   7B  Q4 model : ~0.5–3 s/call  →  20–120 calls/min max
#   13B Q4 model : ~2–8 s/call    →  7–30 calls/min max
#   30B Q4 model : ~10–60 s/call  →  1–6 calls/min max
# If LM Studio is slower than LM_STUDIO_TIMEOUT_SECONDS, the call falls back
# to the cloud provider and local_fallback_count increments in /llm/health.
#
# Option A — LM Studio as primary on the same machine as the backend:
# LLM_PROVIDER=lmstudio
# LLM_FALLBACK_ENABLED=false
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=<exact model name from LM Studio — e.g. lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF>
# LM_STUDIO_TIMEOUT_SECONDS=90
#
# Option A (legacy — explicit enable + cloud as LLM_PROVIDER fallback):
# LM_STUDIO_ENABLED=true
# LM_STUDIO_HOST=127.0.0.1
# LM_STUDIO_PORT=1234
# LM_STUDIO_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF
# LM_STUDIO_TIMEOUT_SECONDS=90
# LM_STUDIO_PROXY_URL=                # leave empty — no proxy needed for localhost
# LM_LINK_ENABLED=false
#
# Option B — LM Link via Tailscale (Render → Mac with LM Studio):
#
# Tailnet devices in this deployment:
#   Mac (LM Studio):  100.112.224.78  port 1234
#   Render service:   100.74.11.123
#
# Render runs Tailscale in userspace-networking mode (no kernel TUN device).
# Traffic to Tailscale peers MUST go through the HTTP CONNECT proxy that
# tailscaled exposes via --outbound-http-proxy-listen=localhost:1055.
# Set LM_STUDIO_PROXY_URL so httpx uses it explicitly.
# Never point LM_STUDIO_HOST at 127.0.0.1:1055 — that is the proxy, not LM Studio.
#
# LLM_PROVIDER=lmstudio
# LLM_FALLBACK_ENABLED=false
# LM_STUDIO_HOST=100.112.224.78      # Tailscale IP of the Mac — NOT 127.0.0.1
# LM_STUDIO_PORT=1234
# LM_STUDIO_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct-GGUF
# LM_STUDIO_TIMEOUT_SECONDS=90
# LM_STUDIO_PROXY_URL=http://127.0.0.1:1055   # Tailscale HTTP CONNECT proxy
# LM_LINK_ENABLED=true
# LM_LINK_DEVICE_NAME=my-mac         # optional — appears in startup logs only
# LM_LINK_TOKEN=                     # only needed if a proxy auth sits in front of LM Studio
# TAILSCALE_AUTHKEY=tskey-auth-...   # Render env var — reusable/ephemeral key
#
# Do NOT set HTTP_PROXY or HTTPS_PROXY globally — they route all traffic
# (health checks, Redis, DB) through Tailscale.  Use LM_STUDIO_PROXY_URL only.
# If other tooling sets ALL_PROXY, add NO_PROXY to protect internal routes:
# NO_PROXY=localhost,127.0.0.1,0.0.0.0,169.254.169.254

# =============================================================================
# OBSERVABILITY (optional)
# =============================================================================

# Langfuse — LLM tracing (https://langfuse.com)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
